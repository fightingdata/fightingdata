---
layout: layout.njk
title: Home
description: UFC Fight Analysis - Data-driven fighter comparisons and matchup breakdowns
---

<!-- Hero Section with background image -->
<section class="hero-section">
    <div class="hero-content">
        <p class="hero-label">UFC Fight Analysis</p>
        <h1 class="hero-title">Data-Driven Fighter<br>Comparisons & Analysis</h1>
        <p class="hero-subtitle">Compare fighters. Analyze matchups. 25 years of UFC history across 10,000+ fights.</p>
        <a href="/events/" class="btn btn-primary">View Upcoming Events</a>
        <div class="hero-stats">
            <div>
                <div class="hero-stat-number">{% if stats.total_fighters %}{{ stats.total_fighters }}{% else %}3,663{% endif %}</div>
                <div class="hero-stat-label">Fighters</div>
            </div>
            <div>
                <div class="hero-stat-number">{% if stats.total_fights %}{{ stats.total_fights }}{% else %}10,951{% endif %}</div>
                <div class="hero-stat-label">Fights</div>
            </div>
            <div>
                <div class="hero-stat-number">{% if stats.total_events %}{{ stats.total_events }}{% else %}1,210{% endif %}</div>
                <div class="hero-stat-label">Events</div>
            </div>
        </div>
    </div>
</section>

<!-- This Week's Event -->
<section style="padding:28px 0;">
    <div class="container">
        {% if events.length > 0 %}
        {% set nextEvent = events[0] %}
        <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:14px;">
            <div>
                <span class="section-label">This Week</span>
                <h2 class="section-title">{{ nextEvent.name }}</h2>
                <p class="section-meta">{{ nextEvent.date }} &bull; {{ nextEvent.location }}</p>
            </div>
            <a href="/events/{{ nextEvent.slug }}/" style="font-size:13px;color:#d62828;font-weight:600;">Full Card →</a>
        </div>

        <div class="card">
            {% if nextEvent.matchups.length > 0 %}
                {% for matchup in nextEvent.matchups | limit(5) %}
                <a href="/compare/{{ matchup.slug }}/" class="matchup-row">
                    {% if loop.first %}<span class="matchup-tag">Main Event</span>{% endif %}
                    <span class="matchup-names{% if loop.first %} main-event{% endif %}">{{ matchup.fighter_a }}{% if matchup.record_a %} <span class="matchup-record">{{ matchup.record_a }}</span>{% endif %} vs. {% if matchup.record_b %}<span class="matchup-record">{{ matchup.record_b }}</span> {% endif %}{{ matchup.fighter_b }}</span>
                    <span class="matchup-weight">{{ matchup.weight_class }}</span>
                </a>
                {% endfor %}
                {% if nextEvent.matchups.length > 5 %}
                <a href="/events/{{ nextEvent.slug }}/" class="matchup-more">+ {{ nextEvent.matchups.length - 5 }} more fights</a>
                {% endif %}
            {% endif %}
        </div>

        <!-- Scheduled Events Table -->
        {% if events.length > 1 %}
        <h3 style="font-size:14px;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:1px;margin:32px 0 12px;">Scheduled Events</h3>
        <div class="card">
            <table class="sched-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Event</th>
                        <th>Location</th>
                        <th>Fights</th>
                    </tr>
                </thead>
                <tbody>
                    {% for event in events %}
                    {% if not loop.first %}
                    <tr onclick="window.location='/events/{{ event.slug }}/'">
                        <td style="color:#555;">{{ event.date }}</td>
                        <td><span class="sched-event-name">{{ event.name.split(':')[0] }}:</span> <span class="sched-event-sub">{{ event.name.split(':')[1] or '' }}</span></td>
                        <td style="color:#555;">{{ event.location.split(',')[0] }}</td>
                        <td style="text-align:center;color:#555;">{{ event.matchups.length }}</td>
                    </tr>
                    {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        {% else %}
        <div class="card" style="padding:48px;text-align:center;">
            <p style="color:#777;">No upcoming events scheduled at this time.</p>
        </div>
        {% endif %}

        <!-- Features -->
        <div class="features-grid">
            <div class="card feature-card">
                <h3>Head-to-Head Comparisons</h3>
                <p>Career stats, recent form, edge indicators, and common opponents for every upcoming matchup.</p>
            </div>
            <div class="card feature-card">
                <h3>25 Years of Fight Data</h3>
                <p>Every UFC fight since November 2000 — striking, grappling, control time, finishes, and round-by-round.</p>
            </div>
            <div class="card feature-card">
                <h3>Updated Every Fight Week</h3>
                <p>Fresh data after every event. New breakdowns published as soon as cards are announced.</p>
            </div>
        </div>
    </div>
</section>

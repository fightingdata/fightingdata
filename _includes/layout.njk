<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | FightingData.com - UFC Fight Analysis</title>
    <meta name="description" content="{{ description or 'UFC fight analysis and fighter statistics. Data-driven insights for every matchup.' }}">
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon.ico">
    <link rel="stylesheet" href="/assets/css/styles.css">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ title }} | FightingData.com">
    <meta property="og:description" content="{{ description or 'UFC fight analysis and fighter statistics.' }}">
    <meta property="og:url" content="https://fightingdata.com{{ page.url }}">
    <meta property="og:type" content="website">

    <link rel="canonical" href="https://fightingdata.com{{ page.url }}">
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Site Header -->
    <header class="site-header">
        <div class="container">
            <a href="/" class="site-logo">FIGHTING<span>DATA</span></a>
            <button class="mobile-menu-btn" onclick="document.querySelector('.site-nav').classList.toggle('mobile-open')" aria-label="Menu">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <nav class="site-nav">
                <a href="/"{% if page.url == "/" %} class="active"{% endif %}>Home</a>
                <a href="/events/"{% if page.url == "/events/" %} class="active"{% endif %}>Events</a>
                <a href="/fighters/"{% if page.url == "/fighters/" %} class="active"{% endif %}>Fighters</a>
                <a href="/about/"{% if page.url == "/about/" %} class="active"{% endif %}>About</a>
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <main id="main-content">
        {{ content | safe }}
    </main>

    <!-- Site Footer -->
    <footer class="site-footer">
        <div class="container">
            <div>
                <div class="footer-brand">FIGHTING<span>DATA</span></div>
                <div class="footer-info">Data sourced from UFCStats.com &middot; &copy; 2026 FightingData.com</div>
            </div>
            <div class="footer-nav">
                <a href="/">Home</a>
                <a href="/events/">Events</a>
                <a href="/fighters/">Fighters</a>
                <a href="/about/">About</a>
            </div>
        </div>
    </footer>

    <script src="/assets/js/main.js"></script>
</body>
</html>
